{
  "name": "xteink-cjk-font-maker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "generate:charsets": "node scripts/generate-charsets.mjs",
    "web:dev": "vite --config web/vite.config.mjs",
    "web:build": "vite build --config web/vite.config.mjs",
    "web:preview": "vite preview --config web/vite.config.mjs",
    "server:dev": "node --watch server/index.js",
    "server:build": "tsc --noCheck --outDir dist --module NodeNext --moduleResolution NodeNext --target ES2022 server/index.ts",
    "server:start": "node dist/server/index.js",
    "build": "npm run web:build && npm run server:build",
    "dev": "concurrently -k -n app,web -c blue,green \"npm run server:dev\" \"VITE_API_PROXY_TARGET=http://127.0.0.1:3000 npm run web:dev\"",
    "start": "npm run server:start"
  },
  "devDependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/node": "^25.3.5",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "lucide-react": "^0.575.0",
    "postcss": "^8.5.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^5.4.21",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "opentype.js": "^1.3.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
